rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required) - Firebase Auth UID
    //   - email: string (required) - User email
    //   - displayName: string (optional) - User display name
    //   - googleAccessToken: string (optional) - Google OAuth access token
    //   - googleRefreshToken: string (optional) - Google OAuth refresh token
    //   - googleTokenExpiry: number (optional) - Google OAuth token expiry timestamp
    //
    // Collection: travel_plans
    // Document ID: {planId}
    // Fields:
    //   - userId: string (required) - UID of the user
    //   - destination: string (required) - Travel destination
    //   - urgency: string (required, enum: ["High", "Low"]) - Urgency based on calendar
    //   - options: list (required) - Travel options generated by AI
    //   - createdAt: timestamp (required) - Creation time
    //
    // Collection: bookings
    // Document ID: {bookingId}
    // Fields:
    //   - userId: string (required) - UID of the user
    //   - planId: string (required) - ID of the travel plan
    //   - mode: string (required) - Selected transport mode
    //   - stay: string (optional) - Booked accommodation
    //   - status: string (required, enum: ["Confirmed", "Pending"]) - Booking status
    //   - createdAt: timestamp (required) - Creation time
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "dineshkuttan78@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'email', 'displayName', 'googleAccessToken', 'googleRefreshToken', 'googleTokenExpiry']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.email is string && data.email.size() < 100;
    }

    function isValidTravelPlan(data) {
      return hasOnlyAllowedFields(['userId', 'destination', 'urgency', 'options', 'createdAt']) &&
             data.userId is string && data.userId == request.auth.uid &&
             data.destination is string && data.destination.size() < 200 &&
             data.urgency in ['High', 'Low'] &&
             data.options is list && data.options.size() < 10 &&
             data.createdAt is timestamp;
    }

    function isValidBooking(data) {
      return hasOnlyAllowedFields(['userId', 'planId', 'mode', 'stay', 'status', 'createdAt']) &&
             data.userId is string && data.userId == request.auth.uid &&
             data.planId is string &&
             data.mode is string &&
             data.status in ['Confirmed', 'Pending'] &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && isOwner(userId);
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && isOwner(userId);
    }

    match /travel_plans/{planId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidTravelPlan(request.resource.data);
      allow update: if isAuthenticated() && isValidTravelPlan(request.resource.data) && isDocOwner();
    }

    match /bookings/{bookingId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidBooking(request.resource.data);
      allow update: if isAuthenticated() && isValidBooking(request.resource.data) && isDocOwner();
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
