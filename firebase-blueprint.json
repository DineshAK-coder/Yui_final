{
  "entities": {
    "User": {
      "title": "User",
      "description": "Stores user profile and OAuth tokens for Google Calendar.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "displayName": { "type": "string", "description": "User display name" },
        "googleAccessToken": { "type": "string", "description": "Google OAuth access token" },
        "googleRefreshToken": { "type": "string", "description": "Google OAuth refresh token" },
        "googleTokenExpiry": { "type": "number", "description": "Google OAuth token expiry timestamp" }
      },
      "required": ["uid", "email"]
    },
    "TravelPlan": {
      "title": "TravelPlan",
      "description": "Stores generated travel plans for a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the user" },
        "destination": { "type": "string", "description": "Travel destination" },
        "urgency": { "type": "string", "enum": ["High", "Low"], "description": "Urgency based on calendar" },
        "options": { "type": "array", "items": { "type": "object" }, "description": "Travel options generated by AI" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "destination", "urgency", "options"]
    },
    "Booking": {
      "title": "Booking",
      "description": "Stores confirmed bookings.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the user" },
        "planId": { "type": "string", "description": "ID of the travel plan" },
        "mode": { "type": "string", "description": "Selected transport mode" },
        "stay": { "type": "string", "description": "Booked accommodation" },
        "status": { "type": "string", "enum": ["Confirmed", "Pending"], "description": "Booking status" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "planId", "mode", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and tokens."
    },
    "/travel_plans/{planId}": {
      "schema": "TravelPlan",
      "description": "Generated travel plans."
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Confirmed bookings."
    }
  }
}
